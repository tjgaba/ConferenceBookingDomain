# Environment variables
# .env.local        — real dev secrets, NEVER commit
# .env.*.local      — any per-environment local overrides, NEVER commit
# .env.production   — committed (placeholder values only, no real secrets)
# .env.local.example — committed (safe template for onboarding)
.env.local
