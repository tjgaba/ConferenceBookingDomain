# .env.local.example — Template for local development environment variables.
#
# USAGE:
#   cp .env.local.example .env.local
#   Fill in the values for your local machine.
#
# This file IS committed to git (safe — contains no real secrets).
# The actual .env.local is gitignored and must never be committed.
#
# Next.js env file load order (dev):
#   .env.local         ← highest priority, your local overrides
#   .env.development   ← shared dev defaults (committed)
#   .env               ← base defaults (committed, no secrets allowed)

# ── API ───────────────────────────────────────────────────────────────────────
# Full URL to the .NET API (include /api suffix).
# Dev default: http://localhost:5230/api
NEXT_PUBLIC_API_BASE_URL=http://localhost:5230/api

# ── SignalR ───────────────────────────────────────────────────────────────────
# Full URL to the SignalR hub endpoint.
# Dev default: http://localhost:5230/hubs/booking
NEXT_PUBLIC_HUB_URL=http://localhost:5230/hubs/booking
